# ---------------- REMINDERS ----------------
def check_reminders():
    now = time.time()
    reminders = memory.get("reminders", [])
    due = [r for r in reminders if isinstance(r, dict) and "time" in r and r["time"] <= now]
    for r in due:
        task = r.get("task", "Reminder")
        speak(task)
    memory["reminders"] = [r for r in reminders if r["time"] > now]
    if due:
        save_memory()

def add_reminder(task, delay=60):
    remind_time = time.time() + delay
    memory["reminders"].append({"task": task, "time": remind_time})
    save_memory()
    speak("Set")

