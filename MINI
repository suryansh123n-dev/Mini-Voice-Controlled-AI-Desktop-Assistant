# ---------------- CALCULATOR ----------------
def normalize_expression(expr):
    expr = expr.lower()
    expr = expr.replace("plus", "+").replace("minus", "-")
    expr = expr.replace("times", "*").replace("multiplied by", "*")
    expr = expr.replace("divide", "/").replace("over", "/")
    expr = expr.replace("power", "**").replace("square root", "math.sqrt")
    return re.sub(r"[^0-9\+\-\*\/\.\(\) ]|math.sqrt", "", expr)

def safe_eval(expr):
    try:
        normalized = normalize_expression(expr)
        result = eval(normalized, {"__builtins__": None, "math": math}, {})
        return result
    except:
        return None

def calculate_from_speech(speech_text):
    result = safe_eval(speech_text)
    if result is not None:
        speak(f"{result}")
    else:
        speak("Fail")

