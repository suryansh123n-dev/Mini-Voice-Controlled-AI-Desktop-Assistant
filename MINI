# ---------------- MEMORY ----------------
def load_memory():
    try:
        with open("memory.json", "r") as f:
            data = json.load(f)
            if "reminders" not in data or not isinstance(data["reminders"], list):
                data["reminders"] = []
            return data
    except:
        return {"name": None, "last_query": None, "last_note": None, "reminders": []}

memory = load_memory()

def save_memory():
    with open("memory.json", "w") as f:
        json.dump(memory, f)

# ---------------- TTS SETUP ----------------
def speak(text):
    print("Mini:", text)
    try:
        engine = pyttsx3.init("sapi5")
        voices = engine.getProperty("voices")
        try:
            engine.setProperty("voice", voices[1].id)  # female
        except:
            engine.setProperty("voice", voices[0].id)
        engine.setProperty("rate", 175)
        engine.say(text)
        engine.runAndWait()
        engine.stop()
    except:
        pass

