# ---------------- NLP ----------------
nlp = pipeline("zero-shot-classification")

def detect_intent(command):
    candidate_labels = [
        "time","calculator","weather","email","youtube","joke","screenshot",
        "open_app","write_note","shutdown","lock","restart","reminder","status",
        "youtube_pause","youtube_replay","youtube_forward","youtube_rewind",
        "youtube_volume_up","youtube_volume_down","news","google_search",
        "volume_up","volume_down","volume_mute","stop"
    ]
    result = nlp(command, candidate_labels)
    return result["labels"][0]

# ---------------- COMMAND HANDLER ----------------
def process_command(command):
    memory["last_query"] = command
    save_memory()
    intent = detect_intent(command)

    if intent == "stop":
        speak("Goodbye")
        exit()

    elif intent == "time":
        now = datetime.datetime.now().strftime("%I:%M %p")
        speak(now)

    elif intent == "youtube":
        speak("Query?")
        q = listen(timeout=7)
        pywhatkit.playonyt(q if q else "music")
        speak("Playing")

    elif intent == "youtube_pause": youtube_pause_play()
    elif intent == "youtube_replay": youtube_replay()
    elif intent == "youtube_forward": youtube_forward()
    elif intent == "youtube_rewind": youtube_rewind()
    elif intent == "youtube_volume_up": youtube_volume_up()
    elif intent == "youtube_volume_down": youtube_volume_down()

    elif intent == "joke": tell_joke()
    elif intent == "weather":
        speak("City?")
        city = listen(timeout=6)
        get_weather(city if city else "Delhi")

    elif intent == "news": get_news()
    elif intent == "google_search":
        speak("What?")
        query = listen(timeout=7)
        google_search(query)

    elif intent == "status": system_status()
    elif intent == "screenshot": take_screenshot()
    elif intent == "calculator":
        speak("Say")
        problem = listen(timeout=10)
        if problem: calculate_from_speech(problem)

    elif intent == "open_app":
        app = command.replace("open", "").strip()
        open_app(app)

    elif intent == "write_note":
        speak("Say")
        note = listen(timeout=12)
        if note: write_note_auto(note)

    elif intent == "email":
        speak("Subject?")
        subject = listen(timeout=7)
        speak("Body?")
        body = listen(timeout=12)
        send_email(MY_EMAIL, subject, body)

    elif intent == "reminder":
        speak("Task?")
        task = listen(timeout=10)
        speak("Minutes?")
        minutes = listen(timeout=5)
        try: delay = int(minutes) * 60
        except: delay = 60
        add_reminder(task, delay)

    elif intent == "shutdown": shutdown_system()
    elif intent == "lock": lock_system()
    elif intent == "restart": restart_system()
    elif intent == "volume_up": volume_up()
    elif intent == "volume_down": volume_down()
    elif intent == "volume_mute": volume_mute()
    else:
        speak("Unknown")

